<Window xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="2025 CPC Plumbing Calculator" Height="800" Width="1050" Background="#f4f4f5">
    <Grid Margin="15">
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="0,0,0,15">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="*"/>
                <ColumnDefinition Width="Auto"/>
                <ColumnDefinition Width="Auto"/>
            </Grid.ColumnDefinitions>
            
            <StackPanel Grid.Column="0" VerticalAlignment="Center">
                <TextBlock Text="Project Plumbing Fixture Calculator" FontSize="18" FontWeight="Bold"/>
                <TextBlock Text="Fractional Method (2025 LAPC / 2025 CPC Tables 422.1 &amp; 4-1)" Foreground="#52525b" FontSize="11"/>
            </StackPanel>

            <StackPanel Grid.Column="1" Orientation="Horizontal" VerticalAlignment="Center" Margin="0,0,20,0">
                <TextBlock Text="Filter by Level:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                <ComboBox x:Name="LevelFilter" Width="150" SelectionChanged="LevelFilter_SelectionChanged"/>
            </StackPanel>
            
            <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center">
                <Button x:Name="CalculateButton" Content="Push Data to Revit" Width="160" Height="30" Background="#2563eb" Foreground="White" Click="Calculate_Click"/>
            </StackPanel>
        </Grid>

        <Border Grid.Row="1" Background="#e2e8f0" CornerRadius="4" Padding="10" Margin="0,0,0,10">
            <StackPanel Orientation="Horizontal">
                <TextBlock Text="Bulk Edit Selected Rows:" VerticalAlignment="Center" FontWeight="Bold" Margin="0,0,10,0"/>
                
                <TextBlock Text="Type:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <ComboBox x:Name="BulkOccType" Width="180" Margin="0,0,15,0"/>
                
                <TextBlock Text="Factor Override:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="BulkFactor" Width="50" Margin="0,0,15,0"/>
                
                <TextBlock Text="Seat/Unit Count:" VerticalAlignment="Center" Margin="0,0,5,0"/>
                <TextBox x:Name="BulkSeats" Width="50" Margin="0,0,15,0"/>
                
                <Button x:Name="ApplyBulkButton" Content="Apply" Width="100" Background="#0f172a" Foreground="White" Click="ApplyBulk_Click"/>
            </StackPanel>
        </Border>

        <Expander Grid.Row="2" x:Name="ErrorPanelExpander" Header="Problem Rooms (0)" Foreground="#b91c1c" Background="#fee2e2" Margin="0,0,0,10" Visibility="Collapsed">
            <ListBox x:Name="ErrorRoomList" MaxHeight="100" Background="#f8fafc" BorderThickness="0" Margin="5"/>
        </Expander>

        <DataGrid Grid.Row="3" x:Name="RoomDataGrid" AutoGenerateColumns="False" CanUserAddRows="False" AlternatingRowBackground="#fafafa" GridLinesVisibility="Horizontal" SelectionMode="Extended" CellEditEnding="DataGrid_CellEditEnding">
            <DataGrid.Columns>
                <DataGridCheckBoxColumn Header="Exclude" Binding="{Binding Exclude, UpdateSourceTrigger=PropertyChanged}" Width="60"/>
                <DataGridTextColumn Header="Number" Binding="{Binding Number}" IsReadOnly="True" Width="70"/>
                <DataGridTextColumn Header="Room Name" Binding="{Binding Name}" IsReadOnly="True" Width="200"/>
                <DataGridTextColumn Header="Area (SF)" Binding="{Binding Area, StringFormat={}{0:F1}}" IsReadOnly="True" Width="80"/>
                <DataGridComboBoxColumn Header="Occupancy Type" x:Name="OccTypeColumn" SelectedItemBinding="{Binding OccType, UpdateSourceTrigger=PropertyChanged}" Width="220"/>
                <DataGridTextColumn Header="Active Factor" Binding="{Binding ActiveFactorDisplay}" IsReadOnly="True" Width="90" Foreground="#52525b"/>
                <DataGridTextColumn Header="Factor Override" Binding="{Binding FactorOverride, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                <DataGridTextColumn Header="Seat/Unit Count" Binding="{Binding SeatUnitCount, UpdateSourceTrigger=PropertyChanged}" Width="100"/>
                <DataGridTextColumn Header="Occupants" Binding="{Binding CalcLoad, StringFormat={}{0:F2}}" IsReadOnly="True" Width="80" Foreground="#2563eb" FontWeight="Bold"/>
            </DataGrid.Columns>
        </DataGrid>

        <Border Grid.Row="4" Background="#f8fafc" BorderBrush="#e4e4e7" BorderThickness="2" CornerRadius="6" Padding="15" Margin="0,15,0,10">
            <StackPanel>
                <TextBlock Text="Level Grand Totals" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                    
                    <StackPanel Grid.Column="0">
                        <TextBlock Text="MALE FIXTURES" FontSize="10" Foreground="#52525b" Margin="0,0,0,5"/>
                        <TextBlock x:Name="lbl_MWC" Text="Water Closets: 0" FontWeight="Bold"/>
                        <TextBlock x:Name="lbl_MUr" Text="Urinals: 0" FontWeight="Bold"/>
                        <TextBlock x:Name="lbl_MLav" Text="Lavatories: 0" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="1">
                        <TextBlock Text="FEMALE FIXTURES" FontSize="10" Foreground="#52525b" Margin="0,0,0,5"/>
                        <TextBlock x:Name="lbl_FWC" Text="Water Closets: 0" FontWeight="Bold"/>
                        <TextBlock x:Name="lbl_FLav" Text="Lavatories: 0" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock Text="ALL-GENDER (AGGREGATE)" FontSize="10" Foreground="#52525b" Margin="0,0,0,5"/>
                        <TextBlock x:Name="lbl_AgWC" Text="Water Closets: 0" Foreground="#2563eb" FontWeight="Bold"/>
                        <TextBlock x:Name="lbl_AgLav" Text="Lavatories: 0" Foreground="#2563eb" FontWeight="Bold"/>
                    </StackPanel>

                    <StackPanel Grid.Column="3">
                        <TextBlock Text="COMMON / TOTALS" FontSize="10" Foreground="#52525b" Margin="0,0,0,5"/>
                        <TextBlock x:Name="lbl_DF" Text="Drinking Fountains: 0" FontWeight="Bold"/>
                        <TextBlock x:Name="lbl_DesignLoad" Text="Total Design Load: 0" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </StackPanel>
        </Border>

        <Expander Grid.Row="5" Header="View Occupancy Math Breakdown" Foreground="#2563eb">
            <ScrollViewer MaxHeight="150" Margin="0,5,0,0">
                <TextBlock x:Name="MathBreakdownText" TextWrapping="Wrap" FontFamily="Consolas" FontSize="11" Background="#f1f5f9" Padding="10"/>
            </ScrollViewer>
        </Expander>
    </Grid>
</Window>